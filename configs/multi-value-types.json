      "repetition": "OPTIONAL"
    },
    {
      "name": "mv_double",
      "physicalType": "LIST",
      "element": { "name": "element", "physicalType": "DOUBLE", "repetition": "REQUIRED" },
      "repetition": "OPTIONAL"
    },
    {
      "name": "mv_string",
